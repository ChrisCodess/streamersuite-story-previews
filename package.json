{
  "name": "streamersuite-story-previews",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./features/*": {
      "types": "./dist/features/*/index.d.ts",
      "import": "./dist/features/*/index.js"
    },
    "./globals.css": "./dist/styles/globals.css",
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "storybook dev -p 6007",
    "build": "tsc -p tsconfig.build.json && bun run build:css",
    "build:css": "mkdir -p dist/styles && cp src/styles/globals.css dist/styles/globals.css",
    "storybook:build": "storybook build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-themes": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "storybook": "^10.4.4",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@effect/platform-bun": ">=4.0.0-beta.78 || >=4.0.0",
    "@effect/platform-node": ">=4.0.0-beta.78 || >=4.0.0",
    "alchemy": "^2.0.0-beta.55",
    "effect": ">=4.0.0-beta.78 || >=4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
